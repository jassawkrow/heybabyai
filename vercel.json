{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml; charset=utf-8"}]
    },
    {
      "source": "/sitemap-(.*).xml",
      "headers": [{"key": "Content-Type", "value": "application/xml; charset=utf-8"}]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
